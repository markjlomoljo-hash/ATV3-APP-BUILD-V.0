# AcneTrex V3 — Phase 3 environment variables
# Copy to .env.local for local dev. Never commit real secret values.

# ---- Supabase (auto-injected by Lovable Cloud) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-only mirrors (used by TanStack server functions)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ---- Lovable AI Gateway (Phase 5+) ----
LOVABLE_API_KEY=

# ---- External integrations (added in later phases) ----
# OpenWeather / weather provider used by /api/weather snapshots
WEATHER_API_KEY=
# Product/ingredient intelligence provider (FormulaLens)
PRODUCT_LOOKUP_API_KEY=
