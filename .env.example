# ML Runtime Mode (cloud/local)
ML_RUNTIME_MODE=cloud

# Google Cloud Project and Region
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Vertex AI Location
VERTEX_AI_LOCATION=us-central1

# Artifact Registry
ARTIFACT_REGISTRY_REPO=acnetrex-ml
ARTIFACT_REGISTRY_IMAGE=ml-engine

# Compute Engine Instance and Zone (for local/offline fallback)
COMPUTE_ENGINE_INSTANCE=your-compute-engine-instance
COMPUTE_ENGINE_ZONE=us-central1-a

# Model Storage Bucket
MODEL_STORAGE_BUCKET=your-model-storage-bucket

# Secret Manager Prefix
SECRET_MANAGER_PREFIX=acnetrex-v3-ml

# Local Model and Cache Paths (for local/offline fallback)
LOCAL_MODEL_PATH=/app/models
LOCAL_CACHE_PATH=/app/cache

# Flags for Vertex AI and Compute Engine Inference
USE_VERTEX_AI_INFERENCE=true
USE_COMPUTE_ENGINE_INFERENCE=false
