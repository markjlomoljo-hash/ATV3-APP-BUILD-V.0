# AcneTrex V3 - Phase 7 environment variables
# Copy to .env.local for local dev. Never commit real secret values.

# ---- Database (Supabase) ----
# Use the Supabase transaction pooler URL in Vercel production.
DATABASE_URL=<SET_IN_VERCEL_SECRET_MANAGER_ONLY>
SUPABASE_DB_URL=<SET_IN_SECRET_MANAGER_ONLY>

# ---- Supabase public/browser config ----
VITE_SUPABASE_URL=https://alobmstvqutteypusmuo.supabase.co
VITE_SUPABASE_ANON_KEY=<SUPABASE_PUBLISHABLE_KEY>
VITE_SUPABASE_PUBLISHABLE_KEY=<SUPABASE_PUBLISHABLE_KEY>
VITE_SUPABASE_PROJECT_ID=alobmstvqutteypusmuo
NEXT_PUBLIC_SUPABASE_URL=https://alobmstvqutteypusmuo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_PUBLISHABLE_KEY>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<SUPABASE_PUBLISHABLE_KEY>

# ---- Supabase server-only mirrors ----
SUPABASE_URL=https://alobmstvqutteypusmuo.supabase.co
SUPABASE_PUBLISHABLE_KEY=<SUPABASE_PUBLISHABLE_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SET_IN_SECRET_MANAGER_ONLY>

# ---- AcneTrex ML / Google Cloud ----
ACNETREX_ML_API_URL=https://mlatv-pudz4xjzxa-ew.a.run.app
NEXT_PUBLIC_ACNETREX_ML_API_URL=https://mlatv-pudz4xjzxa-ew.a.run.app
VITE_ACNETREX_ML_API_URL=https://mlatv-pudz4xjzxa-ew.a.run.app
CLOUD_RUN_MLATV_URL=https://mlatv-pudz4xjzxa-ew.a.run.app

# Vertex AI configuration used by ml-service on Cloud Run.
VERTEX_AI_PROJECT_ID=project-09bedce3-3c99-4a2b-aad
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=5976620302904328192
VERTEX_AI_ENDPOINT_DISPLAY_NAME=acnetrex-endpoint
VERTEX_AI_API_BASE=https://us-central1-aiplatform.googleapis.com/

# ---- Lovable AI Gateway (Phase 5+) ----
LOVABLE_API_KEY=

# ---- External integrations (added in later phases) ----
