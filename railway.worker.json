{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.worker",
    "watchPatterns": [
      "/Dockerfile.worker",
      "/bun.lock",
      "/package.json",
      "/railway.worker.json",
      "/scripts/ml-worker.ts",
      "/src/db/**",
      "/src/lib/acnetrex/ml-analysis-jobs.ts",
      "/src/lib/acnetrex/ml-analysis-worker.ts",
      "/src/lib/acnetrex/ml-worker-runtime.ts",
      "/packages/ml-local-runtime/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health/ready",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 10,
    "drainingSeconds": 30
  }
}
