{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acnetrex.app/schemas/ml/inference-response/1.0.0",
  "title": "AcneTrexInferenceResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "request_id", "module", "task", "result_type", "result", "runtime_mode", "runtime_provider", "readiness_state", "model_name", "model_version", "training_data_version", "feature_schema_version", "input_record_refs", "features_used", "features_missing", "sample_count", "coverage", "confidence", "confidence_label", "calibration_state", "uncertainty", "limitations", "confounders", "evidence_state", "safety_state", "sync_status", "latency_ms", "created_at"],
  "properties": {
    "ok": {"type": "boolean"},
    "request_id": {"type": "string", "format": "uuid"},
    "job_id": {"type": ["string", "null"]},
    "module": {"type": "string"},
    "task": {"type": "string"},
    "result_type": {"type": "string"},
    "result": {"type": ["object", "null"]},
    "runtime_mode": {"enum": ["cloud_run", "cloud_vertex", "local_model", "local_deterministic", "queued_for_cloud", "unavailable"]},
    "runtime_provider": {"type": "string"},
    "readiness_state": {"enum": ["ready", "partial", "insufficient_data", "not_configured", "unsupported_offline", "consent_restricted", "model_unavailable", "evidence_unavailable", "error_retryable", "error_terminal"]},
    "model_name": {"type": ["string", "null"]},
    "model_version": {"type": ["string", "null"]},
    "training_data_version": {"type": ["string", "null"]},
    "feature_schema_version": {"const": "1.0.0"},
    "input_record_refs": {"type": "array", "items": {"type": "string"}},
    "features_used": {"type": "array", "items": {"type": "string"}},
    "features_missing": {"type": "array", "items": {"type": "string"}},
    "sample_count": {"type": "integer", "minimum": 0},
    "coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "confidence_label": {"enum": ["not_applicable", "low", "moderate", "high"]},
    "calibration_state": {"enum": ["not_applicable", "unavailable", "uncalibrated", "calibrated"]},
    "uncertainty": {"type": "array", "items": {"type": "string"}},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "confounders": {"type": "array", "items": {"type": "string"}},
    "evidence_state": {"enum": ["not_applicable", "available", "unavailable"]},
    "safety_state": {"enum": ["ready", "partial", "insufficient_data", "not_configured", "unsupported_offline", "consent_restricted", "model_unavailable", "evidence_unavailable", "error_retryable", "error_terminal"]},
    "sync_status": {"enum": ["local_only", "pending_sync", "synced", "not_applicable"]},
    "latency_ms": {"type": "number", "minimum": 0},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
